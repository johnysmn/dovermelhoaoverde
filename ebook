<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Do Vermelho ao Verde — Saia das Dívidas e Comece a Investir</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

<style>
/* ═══════════════════════════════════════
   RESET & TOKENS
═══════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --green:    #1A7A4A;
  --dkgreen:  #145C38;
  --ltgreen:  #E8F5EE;
  --xltgreen: #F2FAF6;
  --gold:     #C9860D;
  --ltgold:   #FFF8E1;
  --dkgray:   #1E1E1E;
  --mdgray:   #555;
  --ltgray:   #F5F5F5;
  --white:    #FFFFFF;
  --radius:   14px;
  --shadow:   0 8px 40px rgba(26,122,74,.15);
  --ff-head:  'Playfair Display', Georgia, serif;
  --ff-body:  'DM Sans', sans-serif;
}
html { scroll-behavior: smooth; }
body {
  font-family: var(--ff-body);
  color: var(--dkgray);
  background: var(--white);
  overflow-x: hidden;
  line-height: 1.6;
}
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
section { position: relative; }

/* ═══════════════════════════════════════
   UTILITIES
═══════════════════════════════════════ */
.container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.text-center { text-align: center; }
.green { color: var(--green); }
.gold  { color: var(--gold); }

/* ═══════════════════════════════════════
   STICKY NAV
═══════════════════════════════════════ */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 999;
  background: rgba(20,92,56,.97);
  backdrop-filter: blur(10px);
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 24px;
  box-shadow: 0 2px 20px rgba(0,0,0,.25);
  transition: padding .3s;
}
.nav-logo {
  font-family: var(--ff-head);
  font-size: 1.15rem; color: #fff;
  display: flex; align-items: center; gap: 8px;
}
.nav-logo span { color: #AADDCC; }
.nav-cta {
  background: var(--gold);
  color: #fff !important;
  font-weight: 700; font-size: .85rem;
  padding: 10px 22px; border-radius: 50px;
  transition: transform .2s, box-shadow .2s;
  white-space: nowrap;
}
.nav-cta:hover { transform: scale(1.05); box-shadow: 0 4px 20px rgba(201,134,13,.5); }

/* ═══════════════════════════════════════
   HERO
═══════════════════════════════════════ */
.hero {
  min-height: 100vh;
  background: linear-gradient(135deg, #0d3d24 0%, #1A7A4A 55%, #1e9456 100%);
  display: flex; align-items: center;
  padding: 100px 0 60px;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;
}
.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px; align-items: center;
}
.hero-label {
  display: inline-block;
  background: rgba(255,255,255,.12);
  color: #AADDCC;
  font-size: .78rem; font-weight: 700; letter-spacing: 2px;
  padding: 6px 16px; border-radius: 50px;
  text-transform: uppercase; margin-bottom: 22px;
  border: 1px solid rgba(255,255,255,.2);
}
.hero h1 {
  font-family: var(--ff-head);
  font-size: clamp(2.4rem, 5vw, 4rem);
  line-height: 1.1;
  color: #fff;
  margin-bottom: 20px;
}
.hero h1 .accent {
  color: #AADDCC;
  display: block;
}
.hero-sub {
  font-size: 1.1rem; color: rgba(255,255,255,.8);
  max-width: 520px; margin-bottom: 36px; line-height: 1.7;
}
.hero-badges {
  display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 36px;
}
.badge {
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.2);
  color: #D4EDD9; font-size: .82rem; font-weight: 600;
  padding: 6px 14px; border-radius: 50px;
  display: flex; align-items: center; gap: 6px;
}
.hero-cta-group { display: flex; flex-direction: column; gap: 12px; }
.btn-primary {
  display: inline-flex; align-items: center; justify-content: center; gap: 10px;
  background: var(--gold);
  color: #fff; font-weight: 800; font-size: 1.1rem;
  padding: 18px 36px; border-radius: 50px;
  border: none; cursor: pointer;
  box-shadow: 0 8px 30px rgba(201,134,13,.5);
  transition: transform .25s, box-shadow .25s;
  width: fit-content;
}
.btn-primary:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 14px 40px rgba(201,134,13,.6); }
.btn-primary:active { transform: scale(.98); }
.hero-guarantee {
  font-size: .82rem; color: rgba(255,255,255,.65);
  display: flex; align-items: center; gap: 6px;
}
/* Book mockup */
.hero-visual { display: flex; justify-content: center; align-items: center; }
.book-3d {
  position: relative;
  width: 260px; height: 340px;
  animation: float 4s ease-in-out infinite;
}
@keyframes float {
  0%,100% { transform: translateY(0) rotate(-2deg); }
  50% { transform: translateY(-16px) rotate(-2deg); }
}
.book-cover {
  width: 100%; height: 100%;
  background: linear-gradient(145deg, #145C38, #1A7A4A);
  border-radius: 4px 12px 12px 4px;
  position: relative;
  box-shadow:
    -8px 8px 0 #0a2d1e,
    -16px 16px 30px rgba(0,0,0,.4),
    inset 4px 0 8px rgba(255,255,255,.05);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 30px 20px;
  overflow: hidden;
}
.book-cover::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0; width: 20px;
  background: linear-gradient(to right, #0a2d1e, #1A7A4A);
  border-radius: 4px 0 0 4px;
}
.book-cover::after {
  content: '';
  position: absolute; inset: 0;
  background: repeating-linear-gradient(
    135deg, transparent, transparent 2px,
    rgba(255,255,255,.015) 2px, rgba(255,255,255,.015) 4px
  );
}
.book-emoji { font-size: 3.5rem; margin-bottom: 12px; position: relative; z-index: 1; }
.book-title-text {
  font-family: var(--ff-head);
  text-align: center; position: relative; z-index: 1;
}
.book-title-text .line1 { font-size: .9rem; color: rgba(255,255,255,.7); letter-spacing: 1px; }
.book-title-text .line2 { font-size: 1.4rem; font-weight: 900; color: #fff; line-height: 1.1; }
.book-title-text .line3 { font-size: 1.8rem; font-weight: 900; color: #AADDCC; line-height: 1.1; }
.book-sub-text {
  font-size: .68rem; color: rgba(255,255,255,.6);
  text-align: center; position: relative; z-index: 1;
  margin-top: 10px; line-height: 1.4;
}

/* ═══════════════════════════════════════
   PAIN SECTION
═══════════════════════════════════════ */
.pain {
  background: var(--dkgray);
  padding: 80px 0;
}
.pain-heading {
  font-family: var(--ff-head);
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  color: #fff; text-align: center; margin-bottom: 50px;
}
.pain-heading em { color: #AADDCC; font-style: normal; }
.pain-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 24px;
}
.pain-card {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--radius);
  padding: 28px 24px;
  transition: background .3s, transform .3s;
}
.pain-card:hover { background: rgba(26,122,74,.2); transform: translateY(-4px); }
.pain-icon { font-size: 2rem; margin-bottom: 14px; }
.pain-card h3 { color: #fff; font-size: 1rem; font-weight: 700; margin-bottom: 8px; }
.pain-card p { color: rgba(255,255,255,.6); font-size: .9rem; line-height: 1.6; }
.pain-bottom {
  text-align: center; margin-top: 50px;
}
.pain-bottom p {
  font-family: var(--ff-head);
  font-size: 1.4rem; color: #AADDCC;
  font-style: italic;
}
.pain-bottom strong { color: #fff; font-style: normal; }

/* ═══════════════════════════════════════
   PROMISE STRIP
═══════════════════════════════════════ */
.promise-strip {
  background: var(--gold);
  padding: 20px 0;
  overflow: hidden;
  position: relative;
}
.promise-track {
  display: flex; gap: 50px;
  animation: marquee 25s linear infinite;
  white-space: nowrap;
}
@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.promise-item {
  font-weight: 800; font-size: .95rem; color: #fff;
  display: flex; align-items: center; gap: 10px;
  flex-shrink: 0;
}
.promise-sep { color: rgba(255,255,255,.5); }

/* ═══════════════════════════════════════
   WHAT YOU LEARN
═══════════════════════════════════════ */
.learn { padding: 90px 0; background: var(--xltgreen); }
.section-label {
  font-size: .78rem; font-weight: 700; letter-spacing: 2px;
  color: var(--green); text-transform: uppercase;
  margin-bottom: 10px;
}
.section-title {
  font-family: var(--ff-head);
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  line-height: 1.2; margin-bottom: 14px;
}
.section-desc { color: var(--mdgray); max-width: 540px; font-size: 1rem; line-height: 1.7; }
.learn-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 24px; margin-top: 50px;
}
.learn-card {
  background: #fff;
  border-radius: var(--radius);
  padding: 28px 24px;
  border: 1px solid rgba(26,122,74,.1);
  box-shadow: 0 4px 24px rgba(26,122,74,.06);
  display: flex; gap: 18px;
  transition: transform .3s, box-shadow .3s;
}
.learn-card:hover { transform: translateY(-5px); box-shadow: 0 12px 40px rgba(26,122,74,.15); }
.learn-num {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--green); color: #fff;
  font-weight: 800; font-size: .9rem;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.learn-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
.learn-card p { font-size: .88rem; color: var(--mdgray); line-height: 1.6; }

/* ═══════════════════════════════════════
   TESTIMONIALS
═══════════════════════════════════════ */
.testimonials { padding: 90px 0; background: #fff; }
.testi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px; margin-top: 50px;
}
.testi-card {
  background: var(--xltgreen);
  border-radius: var(--radius);
  padding: 30px 26px;
  border-left: 4px solid var(--green);
  position: relative;
  transition: transform .3s;
}
.testi-card:hover { transform: translateY(-5px); }
.testi-quote { font-size: 3rem; color: var(--green); line-height: 1; margin-bottom: 10px; opacity: .3; }
.testi-text { font-size: .95rem; line-height: 1.7; margin-bottom: 20px; color: var(--dkgray); font-style: italic; }
.testi-author { display: flex; align-items: center; gap: 12px; }
.testi-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--green);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; color: #fff; font-weight: 700; flex-shrink: 0;
}
.testi-name { font-weight: 700; font-size: .9rem; }
.testi-role { font-size: .8rem; color: var(--mdgray); }
.stars { color: var(--gold); font-size: .85rem; margin-bottom: 4px; }

/* ═══════════════════════════════════════
   RESULTS COUNTER
═══════════════════════════════════════ */
.results {
  background: var(--green);
  padding: 70px 0;
}
.results-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 30px; text-align: center;
}
.result-item { color: #fff; }
.result-num {
  font-family: var(--ff-head);
  font-size: clamp(2.4rem, 5vw, 3.8rem);
  font-weight: 900; color: #AADDCC;
  display: block;
}
.result-label { font-size: .9rem; color: rgba(255,255,255,.75); margin-top: 4px; }
.result-divider {
  width: 1px; background: rgba(255,255,255,.15);
  align-self: stretch;
}

/* ═══════════════════════════════════════
   CHAPTERS
═══════════════════════════════════════ */
.chapters { padding: 90px 0; background: var(--ltgray); }
.chapters-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 16px; margin-top: 50px;
}
.chapter-item {
  background: #fff;
  border-radius: 10px;
  padding: 18px 20px;
  display: flex; gap: 16px; align-items: flex-start;
  border: 1px solid rgba(0,0,0,.06);
  transition: border-color .3s, transform .3s;
}
.chapter-item:hover { border-color: var(--green); transform: translateX(4px); }
.ch-num {
  font-weight: 900; font-size: 1.5rem; color: var(--green);
  line-height: 1; min-width: 32px;
}
.ch-title { font-weight: 700; font-size: .95rem; margin-bottom: 4px; }
.ch-sub { font-size: .82rem; color: var(--mdgray); }

/* ═══════════════════════════════════════
   URGENCY
═══════════════════════════════════════ */
.urgency {
  background: linear-gradient(135deg, #1e1e1e, #2a2a2a);
  padding: 80px 0;
}
.urgency-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px; align-items: center;
}
.urgency h2 {
  font-family: var(--ff-head);
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  color: #fff; margin-bottom: 20px; line-height: 1.2;
}
.urgency h2 em { color: #AADDCC; font-style: normal; }
.urgency p { color: rgba(255,255,255,.7); font-size: 1rem; line-height: 1.7; margin-bottom: 24px; }
.debt-calc {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--radius);
  padding: 30px;
}
.debt-calc h3 { color: #AADDCC; font-size: 1rem; font-weight: 700; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px; }
.calc-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,.06);
  font-size: .9rem;
}
.calc-label { color: rgba(255,255,255,.6); }
.calc-val { font-weight: 700; }
.calc-val.red { color: #ff6b6b; }
.calc-val.green { color: #AADDCC; }
.calc-total {
  margin-top: 16px; padding-top: 16px;
  border-top: 2px solid rgba(255,255,255,.2);
  display: flex; justify-content: space-between;
  font-size: 1.1rem; font-weight: 800; color: #fff;
}

/* ═══════════════════════════════════════
   PRICING
═══════════════════════════════════════ */
.pricing {
  padding: 90px 0;
  background: var(--xltgreen);
  text-align: center;
}
.price-box {
  max-width: 520px; margin: 50px auto 0;
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 20px 60px rgba(26,122,74,.18);
  overflow: hidden;
  position: relative;
}
.price-badge {
  position: absolute; top: 20px; right: -30px;
  background: var(--gold); color: #fff;
  font-size: .75rem; font-weight: 800;
  padding: 6px 40px;
  transform: rotate(45deg);
  transform-origin: center;
  letter-spacing: 1px; text-transform: uppercase;
}
.price-header {
  background: var(--green);
  padding: 30px 40px;
  color: #fff;
}
.price-header h3 { font-family: var(--ff-head); font-size: 1.5rem; margin-bottom: 6px; }
.price-header p { opacity: .8; font-size: .9rem; }
.price-body { padding: 36px 40px; }
.price-old { color: var(--mdgray); text-decoration: line-through; font-size: 1rem; }
.price-current {
  font-family: var(--ff-head);
  font-size: 3.5rem; font-weight: 900; color: var(--green);
  line-height: 1;
}
.price-current sup { font-size: 1.5rem; vertical-align: super; }
.price-current small { font-size: 1rem; color: var(--mdgray); }
.price-installment { color: var(--mdgray); font-size: .9rem; margin-top: 4px; }
.price-features { text-align: left; margin: 24px 0; }
.price-feature {
  display: flex; gap: 10px; align-items: flex-start;
  padding: 8px 0; border-bottom: 1px solid #f0f0f0;
  font-size: .92rem;
}
.price-feature:last-child { border-bottom: none; }
.feat-check { color: var(--green); font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }
.btn-buy {
  display: block; width: 100%;
  background: var(--gold);
  color: #fff; font-weight: 800; font-size: 1.15rem;
  padding: 18px; border-radius: 50px;
  border: none; cursor: pointer;
  box-shadow: 0 6px 24px rgba(201,134,13,.45);
  transition: transform .2s, box-shadow .2s;
  margin-top: 8px;
}
.btn-buy:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(201,134,13,.55); }
.price-guarantee {
  margin-top: 20px;
  display: flex; gap: 12px; align-items: center;
  background: var(--ltgold); border-radius: 10px;
  padding: 14px 16px;
}
.guarantee-icon { font-size: 1.8rem; flex-shrink: 0; }
.price-guarantee p { font-size: .82rem; color: #7a5c00; line-height: 1.5; }
.price-guarantee strong { font-weight: 700; }

/* ═══════════════════════════════════════
   FAQ
═══════════════════════════════════════ */
.faq { padding: 90px 0; background: #fff; }
.faq-list { max-width: 720px; margin: 50px auto 0; }
.faq-item {
  border: 1px solid rgba(26,122,74,.15);
  border-radius: 10px; margin-bottom: 12px;
  overflow: hidden;
  transition: box-shadow .3s;
}
.faq-item:hover { box-shadow: 0 4px 20px rgba(26,122,74,.1); }
.faq-q {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18px 22px;
  cursor: pointer; font-weight: 700; font-size: .95rem;
  background: #fff; transition: background .2s;
  gap: 12px;
}
.faq-q:hover { background: var(--xltgreen); }
.faq-icon {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--green); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; flex-shrink: 0;
  transition: transform .3s;
}
.faq-item.open .faq-icon { transform: rotate(45deg); }
.faq-a {
  max-height: 0; overflow: hidden;
  transition: max-height .4s ease, padding .3s;
  padding: 0 22px;
  font-size: .9rem; color: var(--mdgray); line-height: 1.7;
}
.faq-item.open .faq-a { max-height: 300px; padding: 0 22px 18px; }

/* ═══════════════════════════════════════
   FINAL CTA
═══════════════════════════════════════ */
.final-cta {
  background: linear-gradient(135deg, #0d3d24 0%, #1A7A4A 100%);
  padding: 100px 0;
  text-align: center;
  overflow: hidden;
  position: relative;
}
.final-cta::before {
  content: '💰';
  position: absolute; font-size: 20rem;
  opacity: .04; top: -60px; right: -60px;
  pointer-events: none;
}
.final-cta h2 {
  font-family: var(--ff-head);
  font-size: clamp(2rem, 5vw, 3.2rem);
  color: #fff; margin-bottom: 18px; line-height: 1.2;
}
.final-cta h2 em { color: #AADDCC; font-style: normal; }
.final-cta p { color: rgba(255,255,255,.75); font-size: 1.05rem; max-width: 560px; margin: 0 auto 36px; line-height: 1.7; }
.btn-primary-lg {
  display: inline-flex; align-items: center; gap: 12px;
  background: var(--gold);
  color: #fff; font-weight: 800; font-size: 1.2rem;
  padding: 20px 46px; border-radius: 50px;
  border: none; cursor: pointer;
  box-shadow: 0 8px 40px rgba(201,134,13,.6);
  transition: transform .25s, box-shadow .25s;
}
.btn-primary-lg:hover { transform: translateY(-4px) scale(1.03); box-shadow: 0 16px 50px rgba(201,134,13,.7); }
.final-meta {
  margin-top: 24px;
  display: flex; justify-content: center; align-items: center; gap: 24px; flex-wrap: wrap;
}
.meta-item { color: rgba(255,255,255,.6); font-size: .85rem; display: flex; gap: 6px; align-items: center; }

/* ═══════════════════════════════════════
   FOOTER
═══════════════════════════════════════ */
footer {
